<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="icyNatural Game OS - test games and rate how they feel." />
  <title>icyNatural — Game OS</title>
  <link rel="stylesheet" href="assets/css/styles.css" />
</head>
<body>
  <div class="shell">
    <header class="topbar panel">
      <div class="brand-wrap">
        <div class="brand-mark">IN</div>
        <div>
          <div class="eyebrow">icyNatural / Game OS</div>
          <h1>Interaction over realism.</h1>
          <p class="subtext">Test games. Rate how they actually feel.</p>
        </div>
      </div>
      <div class="top-actions">
        <button class="btn btn-secondary" id="loadDemoBtn">Load Demo</button>
        <button class="btn btn-primary" id="startTestBtn">Start Test</button>
      </div>
    </header>

    <div class="layout">
      <aside class="sidebar panel">
        <div class="nav-label">Views</div>
        <button class="nav-btn active" data-tab="dashboard">Dashboard <span>01</span></button>
        <button class="nav-btn" data-tab="test">Test Game <span>02</span></button>
        <button class="nav-btn" data-tab="results">Results <span>03</span></button>
        <button class="nav-btn" data-tab="dna">Notes <span>04</span></button>

        <div class="nav-label">Info</div>
        <div class="meta-card">
          <div>Platform</div>
          <strong>Xbox / PC</strong>
        </div>
        <div class="meta-card">
          <div>Latest Score</div>
          <strong id="sidebarScore">8.2</strong>
        </div>

        <div class="sidebar-note">
          Clean game testing. No forced bias.
        </div>
      </aside>

      <main class="main">

        <!-- TEST SECTION -->
        <section class="tab" id="test">
          <section class="panel section-card">
            <div class="section-head">
              <div>
                <div class="eyebrow">Test</div>
                <h3>Test how it feels</h3>
              </div>
            </div>

            <div class="form-grid">
              <label class="field">
                <span>Game Name</span>
                <input id="gameName" type="text" value="Hi-Fi Rush" />
              </label>

              <label class="field">
                <span>Platform</span>

                <!-- ✅ FIXED DROPDOWN -->
                <select id="platform" class="input">
                  <option value="PC">PC</option>
                  <option value="PS5">PS5</option>
                  <option value="Xbox Series">Xbox Series</option>
                  <option value="Switch">Switch</option>
                  <option value="Mobile">Mobile</option>
                  <option value="Retro">Retro</option>
                  <option value="Cloud">Cloud / Streaming</option>
                  <option value="Other">Other</option>
                </select>

              </label>
            </div>

            <!-- rest of your code untouched -->