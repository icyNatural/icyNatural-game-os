<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="icyNatural Game OS - test games and rate how they feel." />
  <title>icyNatural — Game OS</title>
  <link rel="stylesheet" href="assets/css/styles.css" />
</head>
<body>
  <div class="shell">
    <header class="topbar panel">
      <div class="brand-wrap">
        <div class="brand-mark">IN</div>
        <div>
          <div class="eyebrow">icyNatural / Game OS</div>
          <h1>Interaction over realism.</h1>
          <p class="subtext">Test games. Rate how they actually feel.</p>
        </div>
      </div>
      <div class="top-actions">
        <button class="btn btn-secondary" id="loadDemoBtn">Load Demo</button>
        <button class="btn btn-primary" id="startTestBtn">Start Test</button>
      </div>
    </header>

    <div class="layout">
      <aside class="sidebar panel">
        <div class="nav-label">Views</div>
        <button class="nav-btn active" data-tab="dashboard">Dashboard <span>01</span></button>
        <button class="nav-btn" data-tab="test">Test Game <span>02</span></button>
        <button class="nav-btn" data-tab="results">Results <span>03</span></button>
        <button class="nav-btn" data-tab="dna">Notes <span>04</span></button>
        <button class="nav-btn" data-tab="settings">Settings <span>05</span></button>
        <button class="nav-btn" data-tab="history">History <span>06</span></button>

        <div class="nav-label">Info</div>
        <div class="meta-card">
          <div>Platform</div>
          <strong id="sidebarPlatform">Xbox / PC</strong>
        </div>
        <div class="meta-card">
          <div>Latest Score</div>
          <strong id="sidebarScore">8.2</strong>
        </div>

        <div class="sidebar-note">
          Clean game testing. No forced bias.
        </div>
      </aside>

      <main class="main">
        <section class="tab active" id="dashboard">
          <section class="hero panel">
            <div>
              <div class="eyebrow">Latest Test</div>
              <h2>Quick, honest game testing.</h2>
              <p>
                Track what feels good, what falls flat, and what you actually want to come back to.
              </p>
              <div class="hero-actions">
                <button class="btn btn-primary" data-go="test">Test a Game</button>
                <button class="btn btn-secondary" data-go="results">View Results</button>
              </div>
            </div>
            <div class="hero-grid">
              <article class="mini-card">
                <div class="mini-label">Current Game</div>
                <div class="mini-value" id="dashGame">Hi-Fi Rush</div>
                <div class="mini-note">Demo loaded.</div>
              </article>
              <article class="mini-card">
                <div class="mini-label">Score</div>
                <div class="mini-value" id="dashScore" data-value="8.2">8.2</div>
                <div class="mini-note">Live weighted score.</div>
              </article>
              <article class="mini-card">
                <div class="mini-label">Intensity</div>
                <div class="mini-value" id="dashIntensity" data-value="9">9</div>
                <div class="mini-note">How dense the action feels.</div>
              </article>
              <article class="mini-card">
                <div class="mini-label">Replay Pull</div>
                <div class="mini-value" id="dashReplay" data-value="8">8</div>
                <div class="mini-note">Would you run it back?</div>
              </article>
            </div>
          </section>

          <section class="grid-2">
            <article class="panel section-card">
              <div class="section-head">
                <div>
                  <div class="eyebrow">Recent Take</div>
                  <h3 id="recentTakeGame">Hi-Fi Rush</h3>
                </div>
                <button class="btn btn-secondary" data-go="results">Open Results</button>
              </div>

              <div class="score-ring-wrap">
                <div class="score-ring" id="scoreRingDash" style="--score-angle: 295deg;">
                  <div class="score-ring-inner">
                    <div class="score-ring-label">Score</div>
                    <div class="score-big" id="dashRingScore" data-value="8.2">8.2</div>
                  </div>
                </div>
              </div>

              <div class="analysis-list">
                <div class="analysis-item" id="dashVerdict">
                  High interaction density. Strong expression potential. Very responsive control feel. Strong replay pull.
                </div>
                <div class="analysis-item" id="dashNotesPreview">
                  Great combat rhythm. Strong feedback. Moderate freedom but high style factor.
                </div>
              </div>
            </article>

            <article class="panel section-card">
              <div class="section-head">
                <div>
                  <div class="eyebrow">Quick Breakdown</div>
                  <h3>Recent Games</h3>
                </div>
              </div>
              <div id="recentGamesList" class="recent-games-list"></div>
            </article>
          </section>
        </section>

        <section class="tab" id="test">
          <section class="panel section-card">
            <div class="section-head">
              <div>
                <div class="eyebrow">Test</div>
                <h3>Test how it feels</h3>
              </div>
            </div>

            <div class="form-grid">
              <label class="field">
                <span>Game Name</span>
                <input id="gameName" type="text" value="Hi-Fi Rush" />
              </label>

              <label class="field">
                <span>Platform</span>
                <select id="platform" class="input">
                  <option value="PC">PC</option>
                  <option value="PS5">PS5</option>
                  <option value="Xbox Series">Xbox Series</option>
                  <option value="Switch">Switch</option>
                  <option value="Mobile">Mobile</option>
                  <option value="Retro">Retro</option>
                  <option value="Cloud / Streaming">Cloud / Streaming</option>
                  <option value="Other">Other</option>
                </select>
              </label>
            </div>

            <div class="metric-list">
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Control Feel</div><div class="metric-hint">Do inputs feel instant and sharp?</div></div><div class="metric-value" id="controlDisplay">8</div></div><input id="control" type="range" min="1" max="10" value="8" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Freedom</div><div class="metric-hint">Can you approach it your way?</div></div><div class="metric-value" id="freedomDisplay">6</div></div><input id="freedom" type="range" min="1" max="10" value="6" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Expression</div><div class="metric-hint">Can you style, improvise, or flex?</div></div><div class="metric-value" id="expressionDisplay">9</div></div><input id="expression" type="range" min="1" max="10" value="9" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Engagement</div><div class="metric-hint">Did your attention stay locked in?</div></div><div class="metric-value" id="engagementDisplay">9</div></div><input id="engagement" type="range" min="1" max="10" value="9" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Depth</div><div class="metric-hint">Is there enough to grow into?</div></div><div class="metric-value" id="depthDisplay">7</div></div><input id="depth" type="range" min="1" max="10" value="7" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Flow</div><div class="metric-hint">Did time disappear?</div></div><div class="metric-value" id="flowDisplay">8</div></div><input id="flow" type="range" min="1" max="10" value="8" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Intensity</div><div class="metric-hint">How dense was the action?</div></div><div class="metric-value" id="intensityDisplay">9</div></div><input id="intensity" type="range" min="1" max="10" value="9" /></div>
              <div class="metric-row"><div class="metric-top"><div><div class="metric-name">Replay Pull</div><div class="metric-hint">Would you come back to it?</div></div><div class="metric-value" id="replayDisplay">8</div></div><input id="replay" type="range" min="1" max="10" value="8" /></div>
            </div>

            <div class="subsection">
              <div class="field-title">Friction tags</div>
              <div class="tag-row" id="frictionTags">
                <button class="tag" type="button">Slow</button>
                <button class="tag" type="button">Restrictive</button>
                <button class="tag" type="button">Confusing</button>
                <button class="tag" type="button">Repetitive</button>
                <button class="tag" type="button">Clunky</button>
              </div>
            </div>

            <label class="field notes-field">
              <span>Notes</span>
              <textarea id="notes">Great combat rhythm. Strong feedback. Moderate freedom but high style factor.</textarea>
            </label>

            <div class="actions">
              <button class="btn btn-primary" id="calculateBtn">Calculate Result</button>
              <button class="btn btn-secondary" id="resetBtn">Reset</button>
            </div>
          </section>
        </section>

        <section class="tab" id="results">
          <section class="panel section-card result-grid">
            <div>
              <div class="eyebrow">Results</div>
              <h3 id="resultGame">Hi-Fi Rush</h3>

              <div class="score-ring-wrap">
                <div class="score-ring" id="scoreRing" style="--score-angle: 295deg;">
                  <div class="score-ring-inner">
                    <div class="score-ring-label">Score</div>
                    <div class="score-big" id="resultScore" data-value="8.2">8.2</div>
                  </div>
                </div>
              </div>

              <div class="verdict" id="verdictText">
                High interaction density. Strong expression potential. Very responsive control feel. Strong replay pull.
              </div>

              <div class="analysis-item" id="resultUserNote" style="margin-top:14px;">
                Great combat rhythm. Strong feedback. Moderate freedom but high style factor.
              </div>
            </div>

            <div>
              <div class="bar-row"><div class="bar-top"><span>Control Feel</span><span id="resultControlValue">8</span></div><div class="bar-track"><div class="bar-fill" id="resultControl"></div></div></div>
              <div class="bar-row"><div class="bar-top"><span>Freedom</span><span id="resultFreedomValue">6</span></div><div class="bar-track"><div class="bar-fill" id="resultFreedom"></div></div></div>
              <div class="bar-row"><div class="bar-top"><span>Expression</span><span id="resultExpressionValue">9</span></div><div class="bar-track"><div class="bar-fill" id="resultExpression"></div></div></div>
              <div class="bar-row"><div class="bar-top"><span>Engagement</span><span id="resultEngagementValue">9</span></div><div class="bar-track"><div class="bar-fill" id="resultEngagement"></div></div></div>
              <div class="bar-row"><div class="bar-top"><span>Intensity</span><span id="resultIntensityValue">9</span></div><div class="bar-track"><div class="bar-fill" id="resultIntensity"></div></div></div>
              <div class="bar-row"><div class="bar-top"><span>Replay Pull</span><span id="resultReplayValue">8</span></div><div class="bar-track"><div class="bar-fill" id="resultReplay"></div></div></div>
            </div>
          </section>
        </section>

        <section class="tab" id="dna">
          <section class="panel section-card">
            <div class="section-head">
              <div>
                <div class="eyebrow">Notes</div>
                <h3>Honest read</h3>
              </div>
            </div>
            <div class="analysis-list">
              <div class="analysis-item">Use this page to stay honest, not biased.</div>
              <div class="analysis-item">A game can still hit without fitting one fixed lane.</div>
              <div class="analysis-item">Notes matter as much as the score.</div>
            </div>
          </section>
        </section>

        <section class="tab" id="settings">
          <section class="panel section-card">
            <div class="section-head">
              <div>
                <div class="eyebrow">Settings</div>
                <h3>Local controls</h3>
              </div>
            </div>

            <div class="analysis-list">
              <div class="analysis-item">Your site saves the latest game and recent history in this browser only.</div>
              <div class="analysis-item">Use the buttons below if you want to clear saved state or recent games.</div>
            </div>

            <div class="actions" style="margin-top:18px;">
              <button class="btn btn-secondary" id="clearLatestBtn">Clear Latest Game</button>
              <button class="btn btn-secondary" id="clearHistoryBtn">Clear Recent Games</button>
            </div>
          </section>
        </section>
      
        <section class="tab" id="history">
          <section class="panel section-card">
            <div class="section-head">
              <div>
                <div class="eyebrow">History</div>
                <h3>Review Log</h3>
              </div>
            </div>

            <div class="analysis-list" style="margin-bottom:16px;">
              <div class="analysis-item">Full saved review history. Click any row to load it into Results.</div>
            </div>

            <div id="historyGamesList" class="recent-games-list"></div>
          </section>
        </section>
      </main>
    </div>
  </div>

  <script src="assets/js/app.js"></script>
</body>
</html>

